        "text_GVHkQn": {
          "type": "text",
          "settings": {
            "text": "<h2>Before You Apply — Please Read Carefully<br/></h2><p><strong>All U.S. wholesale applicants must submit valid resale documentation with their application.</strong><br/><br/>Your application will not be approved without the required form(s). <br/><br/><strong>To submit an application: </strong></p><p><strong>✓ Complete your wholesale application<br/>✓ Find your state below<br/>✓ Upload the required documents<br/>✓ Submit your application</strong><br/><br/>Applications are typically reviewed within 1 business day.<br/><br/>Requirements vary by state. Please locate your state below and upload the correct documentation on application or email it to <a href=\"hello@bayandstew.com\"><strong>hello@bayandstew.com</strong></a></p>"
          }
        }
      },
