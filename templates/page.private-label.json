    "collapsible_content_yAKnEx": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_wc8MWP": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What is private label production?",
            "icon": "check_mark",
            "row_content": "<p>Private label production allows you to create custom-branded products such as permanent jewelry components, charms, packaging, and inserts designed and produced by Bay & Stew under your brand. It is ideal for makers looking to scale with cohesive, professional branding.</p>",
            "page": ""
          }
        },
        "collapsible_row_zmBBXY": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What types of private label services do you offer?",
            "icon": "check_mark",
            "row_content": "<p>We offer full-service private label support including custom permanent jewelry components, branded packaging, jewelry cases, inserts, promotional items, and custom artwork/design services. Each service is tailored to help elevate your brand experience from product to packaging.</p>",
            "page": ""
          }
        },
        "collapsible_row_mXpPVe": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Can I create custom jewelry components?",
            "icon": "check_mark",
            "row_content": "<p>Yes. We specialize in custom jewelry components such as charms, connectors, and stamped pieces. These can include your logo, symbols, or custom designs to align with your brand identity.</p>",
            "page": ""
          }
        },
        "collapsible_row_4nNHER": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What is the minimum order quantity (MOQ) for private label products?",
            "icon": "check_mark",
            "row_content": "<p>MOQ varies depending on the product type, materials, and customization level. Smaller items like inserts or stickers typically have lower MOQs, while custom jewelry components and packaging require higher minimums. Exact MOQs will be provided after reviewing your inquiry.</p>",
            "page": ""
          }
        },
        "collapsible_row_4iUYxg": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Can I request design help if I don’t have a finished concept?",
            "icon": "check_mark",
            "row_content": "<p>Yes. Our in-house design team can help you develop your idea from concept to production. Whether you have a rough idea, inspiration, or a full mood board, we can assist with artwork, branding, and design direction.</p>",
            "page": ""
          }
        },
        "collapsible_row_UMA9tr": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What types of businesses is private label best for?",
            "icon": "check_mark",
            "row_content": "<p>Private label services are ideal for permanent jewelry makers, small jewelry brands scaling into wholesale, event-based businesses, educators, workshop hosts, and creators launching or expanding their jewelry line.</p>",
            "page": ""
          }
        },
        "collapsible_row_qkYnfy": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How long does private label production take?",
            "icon": "check_mark",
            "row_content": "<p>Production timelines vary based on order size, customization level, and materials. Once your request is reviewed, we will provide a clear estimated timeline tailored to your project.</p>",
            "page": ""
          }
        },
        "collapsible_row_BnMFja": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Can I request multiple products in one private label order?",
            "icon": "check_mark",
            "row_content": "<p>Yes. You can bundle multiple services such as jewelry components, packaging, and inserts into one cohesive private label order. We can help you create a full branded product experience.</p>",
            "page": ""
          }
        }
      },
