      "blocks": {
        "collapsible_row_KBwzPm": {
          "type": "collapsible_row",
          "settings": {
            "heading": "🧾 Wholesale & Sales Tax Exemption Requirements",
            "icon": "check_mark",
            "row_content": "<p>To purchase <strong>wholesale (tax-exempt)</strong> from us, we need a copy of your resale certificate or exemption form. Requirements vary by state — please review the list below before submitting your documentation.</p>",
            "page": ""
          }
        },
        "collapsible_row_RfABMz": {
          "type": "collapsible_row",
          "settings": {
            "heading": "✅ States That Require a State Resale Certificate",
            "icon": "check_mark",
            "row_content": "<p>Submit a <strong>state-issued resale certificate</strong> (or seller’s permit) if you're located in:</p><ul><li><strong>Alabama</strong> – Sales Tax License</li><li><strong>Arizona</strong> – Transaction Privilege Tax (TPT) License</li><li><strong>California</strong> – CDTFA Seller’s Permit</li><li><strong>Colorado</strong> – Sales Tax License</li><li><strong>Connecticut</strong> – Resale Certificate (Form OR-219)</li><li><strong>Florida</strong> – Annual Resale Certificate</li><li><strong>Georgia</strong> – ST-5 Certificate</li><li><strong>Hawaii</strong> – GET License</li><li><strong>Illinois</strong> – CRT-61 Certificate</li><li><strong>Indiana</strong> – ST-105 Certificate</li><li><strong>Iowa</strong> – Sales Tax Exemption Certificate</li><li><strong>Kansas</strong> – ST-28A Certificate</li><li><strong>Kentucky</strong> – 51A105 Resale Certificate</li><li><strong>Louisiana</strong> – R-1042 Certificate</li><li><strong>Maine</strong> – Retail Certificate Number</li><li><strong>Maryland</strong> – Sales & Use License</li><li><strong>Massachusetts</strong> – ST-4 Certificate</li><li><strong>Michigan</strong> – Form 3372</li><li><strong>Minnesota</strong> – ST3 Certificate</li><li><strong>Mississippi</strong> – Sales Tax Permit</li><li><strong>Missouri</strong> – Form 149</li><li><strong>Nebraska</strong> – Form 13</li><li><strong>Nevada</strong> – Sales Tax Permit + Certificate</li><li><strong>New Jersey</strong> – ST-3 Certificate</li><li><strong>New Mexico</strong> – NTTC Certificate</li><li><strong>New York</strong> – ST-120 Certificate</li><li><strong>North Carolina</strong> – E-595E Form</li><li><strong>North Dakota</strong> – Sales Tax Permit</li><li><strong>Ohio</strong> – STEC-U or STEC-B</li><li><strong>Oklahoma</strong> – Resale Permit</li><li><strong>Pennsylvania</strong> – REV-1220 Certificate</li><li><strong>Rhode Island</strong> – Resale Certificate</li><li><strong>South Carolina</strong> – ST-8A Certificate</li><li><strong>South Dakota</strong> – Sales Tax License</li><li><strong>Tennessee</strong> – Certificate of Resale</li><li><strong>Texas</strong> – Form 01-339</li><li><strong>Utah</strong> – TC-721 Certificate</li><li><strong>Vermont</strong> – S-3 Certificate</li><li><strong>Virginia</strong> – ST-10 Certificate</li><li><strong>Washington</strong> – Reseller Permit</li><li><strong>West Virginia</strong> – Exemption Certificate</li><li><strong>Wisconsin</strong> – S-211 Certificate</li><li><strong>Wyoming</strong> – Sales Tax License + Certificate</li></ul>",
            "page": ""
          }
        },
        "collapsible_row_Qhxbzm": {
          "type": "collapsible_row",
          "settings": {
            "heading": "📄 States That Accept the Multistate Uniform Sales Tax Certificate",
            "icon": "check_mark",
            "row_content": "<p>These states allow use of the <strong>MTC Uniform Sales & Use Tax Certificate</strong>:</p><p><em>Alabama, Arizona, Arkansas, California, Colorado, Connecticut, Florida, Hawaii, Idaho, Illinois, Iowa, Kansas, Kentucky, Maine, Maryland, Michigan, Minnesota, Missouri, Nebraska, Nevada, New Jersey, North Carolina, North Dakota, Ohio, Oklahoma, Pennsylvania, Rhode Island, South Dakota, Tennessee, Texas, Utah, Vermont, Washington, West Virginia, Wisconsin, Wyoming</em></p><p><a href=\"https://www.mtc.gov/wp-content/uploads/2023/01/Unif-Resale-Cert-revised-10-14-22.pdf\" title=\"https://www.mtc.gov/wp-content/uploads/2023/01/Unif-Resale-Cert-revised-10-14-22.pdf\">👉 Download the MTC Form (PDF)</a></p>",
            "page": ""
          }
        },
        "collapsible_row_QUQtgG": {
          "type": "collapsible_row",
          "settings": {
            "heading": "🚫 States With No Sales Tax",
            "icon": "check_mark",
            "row_content": "<p>If you’re based in one of these states, no documentation is required:</p><ul><li><strong>Delaware</strong></li><li><strong>Montana</strong></li><li><strong>New Hampshire</strong></li><li><strong>Oregon</strong></li><li><strong>Alaska</strong> <em>(note: some cities do charge local sales tax)</em></li></ul>",
            "page": ""
          }
        }
      },
