{% doc %}
  @prompt
    feature checklist with row, gap, icon size, title font size subtext size options, allow for icon image upload for each and icon size adjustments.  Include subtext and paragraph style options for text or links.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-checklist-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 20px;
  }

  .ai-feature-checklist__list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout }};
    gap: {{ block.settings.gap }}px;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .ai-feature-checklist__item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    {% if block.settings.layout == 'row' %}
      flex: 1 1 auto;
      min-width: 200px;
    {% else %}
      width: 100%;
    {% endif %}
  }

  .ai-feature-checklist__icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-feature-checklist__icon-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-feature-checklist__icon-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.default_icon_color }};
  }

  .ai-feature-checklist__content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-feature-checklist__title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    line-height: 1.3;
  }

  .ai-feature-checklist__subtext-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    line-height: 1.5;
  }

  .ai-feature-checklist__subtext-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: {{ block.settings.link_style }};
  }

  .ai-feature-checklist__subtext-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
    text-decoration: {{ block.settings.link_hover_style }};
  }

  @media screen and (max-width: 749px) {
    .ai-feature-checklist__list-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-feature-checklist__item-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<feature-checklist-{{ ai_gen_id }} class="ai-feature-checklist-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <ul class="ai-feature-checklist__list-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign title_key = 'feature_' | append: i | append: '_title'
        assign subtext_key = 'feature_' | append: i | append: '_subtext'
        assign icon_key = 'feature_' | append: i | append: '_icon'
        assign enabled_key = 'feature_' | append: i | append: '_enabled'

        assign title = block.settings[title_key]
        assign subtext = block.settings[subtext_key]
        assign icon = block.settings[icon_key]
        assign enabled = block.settings[enabled_key]
      %}

      {% if enabled %}
        <li class="ai-feature-checklist__item-{{ ai_gen_id }}">
          <div class="ai-feature-checklist__icon-wrapper-{{ ai_gen_id }}">
            {% if icon %}
              <img
                src="{{ icon | image_url: width: 200 }}"
                alt="{{ title | escape }}"
                loading="lazy"
                width="{{ block.settings.icon_size }}"
                height="{{ block.settings.icon_size }}"
              >
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            {% endif %}
          </div>
          <div class="ai-feature-checklist__content-{{ ai_gen_id }}">
            {% if title != blank %}
              <h3 class="ai-feature-checklist__title-{{ ai_gen_id }}">{{ title }}</h3>
            {% endif %}
            {% if subtext != blank %}
              <div class="ai-feature-checklist__subtext-{{ ai_gen_id }}">{{ subtext }}</div>
            {% endif %}
          </div>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</feature-checklist-{{ ai_gen_id }}>

<script>
  (function() {
    class FeatureChecklist{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const list = this.querySelector('.ai-feature-checklist__list-{{ ai_gen_id }}');
        if (list) {
          list.setAttribute('role', 'list');
          const items = list.querySelectorAll('.ai-feature-checklist__item-{{ ai_gen_id }}');
          items.forEach(item => {
            item.setAttribute('role', 'listitem');
          });
        }
      }
    }

    customElements.define('feature-checklist-{{ ai_gen_id }}', FeatureChecklist{{ ai_gen_id }});
  })();
</script>

{% schema %}
