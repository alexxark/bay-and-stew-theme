{% doc %}
  @prompt
    feature checklist with row, gap, icon size, title font size subtext size options, allow for icon image upload for each and icon size options. I want to make sure I have dedicated settings for styling paragraph text styles.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-checklist-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-feature-checklist__list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout }};
    gap: {{ block.settings.gap }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-feature-checklist__item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ block.settings.icon_text_gap }}px;
  }

  .ai-feature-checklist__icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-feature-checklist__icon-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-feature-checklist__icon-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-feature-checklist__content-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-feature-checklist__title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_subtext_gap }}px 0;
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    line-height: 1.3;
  }

  .ai-feature-checklist__subtext-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.subtext_font_size }}px;
    font-weight: {{ block.settings.subtext_font_weight }};
    color: {{ block.settings.subtext_color }};
    line-height: {{ block.settings.subtext_line_height }};
  }

  @media screen and (max-width: 749px) {
    .ai-feature-checklist__list-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }
{% endstyle %}

<div class="ai-feature-checklist-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <ul class="ai-feature-checklist__list-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign title_key = 'feature_' | append: i | append: '_title'
        assign subtext_key = 'feature_' | append: i | append: '_subtext'
        assign icon_key = 'feature_' | append: i | append: '_icon'
        
        assign feature_title = block.settings[title_key]
        assign feature_subtext = block.settings[subtext_key]
        assign feature_icon = block.settings[icon_key]
      %}
      
      {% if feature_title != blank %}
        <li class="ai-feature-checklist__item-{{ ai_gen_id }}">
          <div class="ai-feature-checklist__icon-wrapper-{{ ai_gen_id }}">
            {% if feature_icon != blank %}
              <img
                src="{{ feature_icon | image_url: width: 200 }}"
                alt="{{ feature_title | escape }}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            {% endif %}
          </div>
          <div class="ai-feature-checklist__content-{{ ai_gen_id }}">
            <h3 class="ai-feature-checklist__title-{{ ai_gen_id }}">{{ feature_title }}</h3>
            {% if feature_subtext != blank %}
              <p class="ai-feature-checklist__subtext-{{ ai_gen_id }}">{{ feature_subtext }}</p>
            {% endif %}
          </div>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</div>

