{% doc %}
  @prompt
    feature checklist with row, gap, icon size, title font size subtext size options, allow for icon image upload for each and icon sizing features.  include dedicated settings for styling headings or links separately in title and subtext fields
    
    , gap between title and subtext is not working
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-checklist-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-feature-checklist__list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout }};
    gap: {{ block.settings.gap }}px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-feature-checklist__item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ block.settings.icon_text_gap }}px;
  }

  .ai-feature-checklist__icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-feature-checklist__icon-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-feature-checklist__icon-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.default_icon_color }};
  }

  .ai-feature-checklist__content-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.title_subtext_gap }}px;
  }

  .ai-feature-checklist__title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    line-height: 1.3;
  }

  .ai-feature-checklist__title-{{ ai_gen_id }} h1,
  .ai-feature-checklist__title-{{ ai_gen_id }} h2,
  .ai-feature-checklist__title-{{ ai_gen_id }} h3,
  .ai-feature-checklist__title-{{ ai_gen_id }} h4,
  .ai-feature-checklist__title-{{ ai_gen_id }} h5,
  .ai-feature-checklist__title-{{ ai_gen_id }} h6 {
    margin: 0;
    font-size: {{ block.settings.title_heading_font_size }}px;
    color: {{ block.settings.title_heading_color }};
    line-height: 1.2;
  }

  .ai-feature-checklist__title-{{ ai_gen_id }} a {
    color: {{ block.settings.title_link_color }};
    text-decoration: {{ block.settings.title_link_underline }};
  }

  .ai-feature-checklist__title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.title_link_hover_color }};
  }

  .ai-feature-checklist__subtext-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.subtext_font_size }}px;
    color: {{ block.settings.subtext_color }};
    line-height: 1.5;
  }

  .ai-feature-checklist__subtext-{{ ai_gen_id }} h1,
  .ai-feature-checklist__subtext-{{ ai_gen_id }} h2,
  .ai-feature-checklist__subtext-{{ ai_gen_id }} h3,
  .ai-feature-checklist__subtext-{{ ai_gen_id }} h4,
  .ai-feature-checklist__subtext-{{ ai_gen_id }} h5,
  .ai-feature-checklist__subtext-{{ ai_gen_id }} h6 {
    margin: 0;
    font-size: {{ block.settings.subtext_heading_font_size }}px;
    color: {{ block.settings.subtext_heading_color }};
    line-height: 1.3;
  }

  .ai-feature-checklist__subtext-{{ ai_gen_id }} a {
    color: {{ block.settings.subtext_link_color }};
    text-decoration: {{ block.settings.subtext_link_underline }};
  }

  .ai-feature-checklist__subtext-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.subtext_link_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-feature-checklist__list-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }
{% endstyle %}

<feature-checklist-{{ ai_gen_id }} class="ai-feature-checklist-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <ul class="ai-feature-checklist__list-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign title_key = 'feature_' | append: i | append: '_title'
        assign subtext_key = 'feature_' | append: i | append: '_subtext'
        assign icon_key = 'feature_' | append: i | append: '_icon'
        
        assign title = block.settings[title_key]
        assign subtext = block.settings[subtext_key]
        assign icon = block.settings[icon_key]
      %}

      {% if title != blank or subtext != blank %}
        <li class="ai-feature-checklist__item-{{ ai_gen_id }}">
          <div class="ai-feature-checklist__icon-wrapper-{{ ai_gen_id }}">
            {% if icon != blank %}
              <img
                src="{{ icon | image_url: width: 200 }}"
                alt=""
                loading="lazy"
                width="{{ block.settings.icon_size }}"
                height="{{ block.settings.icon_size }}"
              >
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            {% endif %}
          </div>
          <div class="ai-feature-checklist__content-{{ ai_gen_id }}">
            {% if title != blank %}
              <div class="ai-feature-checklist__title-{{ ai_gen_id }}">
                {{ title }}
              </div>
            {% endif %}
            {% if subtext != blank %}
              <div class="ai-feature-checklist__subtext-{{ ai_gen_id }}">
                {{ subtext }}
              </div>
            {% endif %}
          </div>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</feature-checklist-{{ ai_gen_id }}>

<script>
  (function() {
    class FeatureChecklist{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('feature-checklist-{{ ai_gen_id }}', FeatureChecklist{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
