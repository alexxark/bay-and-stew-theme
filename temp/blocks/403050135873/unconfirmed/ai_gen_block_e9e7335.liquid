{% doc %}
  @prompt
    Create a featured checklist section with adjustable row gap, icon size, title font size, and subtext font size.
    Each item should include:
    
    Icon image upload with adjustable size
    Title (single-line text)
    Subtext (single-line text, no paragraph spacing)
    
    Below the checklist, include a separate Rich Text (WYSIWYG) field for body content that supports:
    
    paragraphs
    bold / italic
    links
    bullet and numbered lists
    
    Ensure no extra margin or padding is added between title and subtext, and spacing is controlled only by a defined gap setting.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-checklist-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-checklist__items-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.row_gap }}px;
    margin-bottom: {{ block.settings.body_top_spacing }}px;
  }

  .ai-checklist__item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ block.settings.icon_text_gap }}px;
  }

  .ai-checklist__icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-checklist__icon-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-checklist__icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e0e0e0;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-checklist__icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-checklist__text-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ai-checklist__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    padding: 0;
    line-height: 1.3;
  }

  .ai-checklist__subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_font_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0;
    padding: 0;
    line-height: 1.4;
  }

  .ai-checklist__body-{{ ai_gen_id }} {
    color: {{ block.settings.body_color }};
    font-size: {{ block.settings.body_font_size }}px;
    line-height: 1.6;
  }

  .ai-checklist__body-{{ ai_gen_id }} p {
    margin: 0 0 1em 0;
  }

  .ai-checklist__body-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-checklist__body-{{ ai_gen_id }} ul,
  .ai-checklist__body-{{ ai_gen_id }} ol {
    margin: 0 0 1em 0;
    padding-left: 1.5em;
  }

  .ai-checklist__body-{{ ai_gen_id }} ul:last-child,
  .ai-checklist__body-{{ ai_gen_id }} ol:last-child {
    margin-bottom: 0;
  }

  .ai-checklist__body-{{ ai_gen_id }} a {
    color: {{ block.settings.body_link_color }};
    text-decoration: underline;
  }

  .ai-checklist__body-{{ ai_gen_id }} a:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .ai-checklist-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<featured-checklist-{{ ai_gen_id }} class="ai-checklist-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-checklist__items-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign title_key = 'item_' | append: i | append: '_title'
        assign subtext_key = 'item_' | append: i | append: '_subtext'
        assign icon_key = 'item_' | append: i | append: '_icon'
        
        assign item_title = block.settings[title_key]
        assign item_subtext = block.settings[subtext_key]
        assign item_icon = block.settings[icon_key]
      %}
      
      {% if item_title != blank or item_subtext != blank or item_icon != blank %}
        <div class="ai-checklist__item-{{ ai_gen_id }}">
          <div class="ai-checklist__icon-wrapper-{{ ai_gen_id }}">
            {% if item_icon %}
              <img
                src="{{ item_icon | image_url: width: 200 }}"
                alt="{{ item_title | escape }}"
                loading="lazy"
                width="{{ block.settings.icon_size }}"
                height="{{ block.settings.icon_size }}"
              >
            {% else %}
              <div class="ai-checklist__icon-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="ai-checklist__text-{{ ai_gen_id }}">
            {% if item_title != blank %}
              <div class="ai-checklist__title-{{ ai_gen_id }}">{{ item_title }}</div>
            {% endif %}
            {% if item_subtext != blank %}
              <div class="ai-checklist__subtext-{{ ai_gen_id }}">{{ item_subtext }}</div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if block.settings.body_content != blank %}
    <div class="ai-checklist__body-{{ ai_gen_id }}">
      {{ block.settings.body_content }}
    </div>
  {% endif %}
</featured-checklist-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedChecklist{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('featured-checklist-{{ ai_gen_id }}', FeaturedChecklist{{ ai_gen_id }});
  })();
</script>

