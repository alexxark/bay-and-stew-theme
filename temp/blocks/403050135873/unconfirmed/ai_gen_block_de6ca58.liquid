{% doc %}
  @prompt
    Add horizontal padding (left and right) to the Feature Checklist block (ID: template--26201080529217__1774910843ea067923__ai_gen_block_aeb1d89_wXyJhe) inside section template--26201080529217__1774910843ea067923 so there is spacing from the edge of the page to where the icons and content start.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-checklist-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
  }

  .ai-feature-checklist__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-feature-checklist__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-feature-checklist__list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-feature-checklist__item-{{ ai_gen_id }} {
    display: flex;
    align-items: {{ block.settings.icon_alignment }};
    gap: {{ block.settings.icon_text_gap }}px;
  }

  .ai-feature-checklist__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-feature-checklist__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-feature-checklist__text-{{ ai_gen_id }} {
    flex-grow: 1;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-feature-checklist-{{ ai_gen_id }} {
      padding: {{ block.settings.vertical_padding | times: 0.7 }}px {{ block.settings.mobile_horizontal_padding }}px;
    }

    .ai-feature-checklist__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-feature-checklist__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-feature-checklist-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-checklist__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-feature-checklist__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    <ul class="ai-feature-checklist__list-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% assign feature_key = 'feature_' | append: i %}
        {% assign feature_text = block.settings[feature_key] %}
        
        {% if feature_text != blank %}
          <li class="ai-feature-checklist__item-{{ ai_gen_id }}">
            <div class="ai-feature-checklist__icon-{{ ai_gen_id }}">
              {% if block.settings.icon_style == 'checkmark' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              {% elsif block.settings.icon_style == 'circle_check' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                  <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
              {% elsif block.settings.icon_style == 'star' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
              {% elsif block.settings.icon_style == 'plus' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              {% elsif block.settings.icon_style == 'arrow' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              {% endif %}
            </div>
            <div class="ai-feature-checklist__text-{{ ai_gen_id }}">{{ feature_text }}</div>
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</div>

