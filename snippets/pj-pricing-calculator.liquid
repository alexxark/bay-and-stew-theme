{%- comment -%}
  PJ (Permanent Jewelry) Pricing Calculator

  Accepts:
    - product: {Object} the product object
    - section_id: {String} the parent section id

  Behavior:
    - Reads the per-foot chain price from a server-injected JSON map of
      variants (so it works regardless of B2B/wholesale price locks).
    - If the variant has volume (quantity) price breaks, picks the price
      that applies to the current quantity input.
    - Markup multiplier only applies to the final Retail Price.
{%- endcomment -%}

{%- liquid
  assign sid = section_id | default: section.id
-%}

<div
  class="pj-pricing-calculator"
  data-pj-calculator
  data-section-id="{{ sid }}"
  data-product-id="{{ product.id }}"
>
  <script type="application/json" data-pj-variants>
    {
      "default_variant_id": {{ product.selected_or_first_available_variant.id | json }},
      "variants": {
        {%- for v in product.variants -%}
          "{{ v.id }}": {
            "price": {{ v.price | divided_by: 100.0 | json }},
            "breaks": [
              {%- for b in v.quantity_price_breaks -%}
                { "min": {{ b.minimum_quantity | json }}, "price": {{ b.price | divided_by: 100.0 | json }} }{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            ]
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      }
    }
  </script>

  <table class="pj-calc__table">
    <tbody>
      <tr>
        <th scope="row">Chain cost ($ per foot)</th>
        <td><span data-pj-foot>$0.00</span></td>
      </tr>
      <tr>
        <th scope="row">Chain cost ($ per inch)</th>
        <td><span data-pj-inch>$0.00</span></td>
      </tr>
      <tr>
        <th scope="row">
          <label for="PJCalc-Multiplier-{{ sid }}">Markup Multiplier</label>
        </th>
        <td>
          <div class="pj-calc__slider-row">
            <input
              type="range"
              id="PJCalc-Multiplier-{{ sid }}"
              data-pj-multiplier
              min="3"
              max="6"
              step="0.1"
              value="4"
            >
            <span data-pj-multiplier-display>4.0x</span>
          </div>
        </td>
      </tr>
      <tr>
        <th scope="row">Selling Price (per inch)</th>
        <td><span data-pj-selling-inch>$0.00</span></td>
      </tr>
      <tr>
        <th scope="row">
          <label for="PJCalc-Length-{{ sid }}">
            <span data-pj-length-display>7</span>-inch bracelet
          </label>
        </th>
        <td>
          <div class="pj-calc__inline-row">
            <select id="PJCalc-Length-{{ sid }}" data-pj-length>
              {% for i in (4..10) -%}
                <option value="{{ i }}"{% if i == 7 %} selected{% endif %}>{{ i }}"</option>
              {%- endfor %}
            </select>
            <span data-pj-bracelet-price>$0.00</span>
          </div>
        </td>
      </tr>
      <tr>
        <th scope="row">
          <label for="PJCalc-Other-{{ sid }}">Other Material Costs ($)</label>
        </th>
        <td>
          <input
            type="number"
            id="PJCalc-Other-{{ sid }}"
            data-pj-other
            min="0"
            step="0.01"
            value="2.00"
          >
        </td>
      </tr>
      <tr>
        <th scope="row">
          <label for="PJCalc-Labor-{{ sid }}">Labor + Etc.</label>
        </th>
        <td>
          <input
            type="number"
            id="PJCalc-Labor-{{ sid }}"
            data-pj-labor
            min="0"
            step="0.01"
            placeholder="0.00"
          >
        </td>
      </tr>
      <tr>
        <th scope="row">Bracelet Total Cost</th>
        <td><span data-pj-total-cost>$0.00</span></td>
      </tr>
      <tr class="pj-calc__retail">
        <th scope="row">Retail Price</th>
        <td><strong data-pj-retail>$0.00</strong></td>
      </tr>
    </tbody>
  </table>
</div>

<style>
  .pj-pricing-calculator { font-size: 1.4rem; }
  .pj-calc__table { width: 100%; border-collapse: collapse; }
  .pj-calc__table th,
  .pj-calc__table td {
    padding: 10px 6px;
    text-align: left;
    vertical-align: middle;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
    font-size: 1.4rem;
  }
  .pj-calc__table th { font-weight: 500; }
  .pj-calc__table td { text-align: right; }
  .pj-calc__inline-row,
  .pj-calc__slider-row {
    display: flex;
    align-items: center;
    gap: 10px;
    justify-content: flex-end;
  }
  .pj-calc__slider-row input[type='range'] { flex: 1; max-width: 180px; }
  .pj-pricing-calculator input[type='number'],
  .pj-pricing-calculator select {
    width: 100px;
    padding: 6px 8px;
    border: 1px solid rgba(var(--color-foreground), 0.3);
    border-radius: 4px;
    text-align: right;
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    font-size: 1.4rem;
  }
  .pj-calc__retail th,
  .pj-calc__retail td {
    font-size: 1.6rem;
    border-top: 2px solid rgba(var(--color-foreground), 0.4);
    border-bottom: none;
    padding-top: 14px;
  }
</style>

<script>
  (function () {
    var calculators = document.querySelectorAll('[data-pj-calculator]');
    var root = calculators[calculators.length - 1];
    if (!root || root.dataset.pjInit === '1') return;
    root.dataset.pjInit = '1';

    var sectionId = root.dataset.sectionId;

    var data;
    try {
      data = JSON.parse(root.querySelector('[data-pj-variants]').textContent);
    } catch (e) {
      data = { default_variant_id: null, variants: {} };
    }

    var currentVariantId = data.default_variant_id;

    var els = {
      foot: root.querySelector('[data-pj-foot]'),
      inch: root.querySelector('[data-pj-inch]'),
      multiplier: root.querySelector('[data-pj-multiplier]'),
      multiplierDisplay: root.querySelector('[data-pj-multiplier-display]'),
      sellingInch: root.querySelector('[data-pj-selling-inch]'),
      length: root.querySelector('[data-pj-length]'),
      lengthDisplay: root.querySelector('[data-pj-length-display]'),
      braceletPrice: root.querySelector('[data-pj-bracelet-price]'),
      other: root.querySelector('[data-pj-other]'),
      labor: root.querySelector('[data-pj-labor]'),
      totalCost: root.querySelector('[data-pj-total-cost]'),
      retail: root.querySelector('[data-pj-retail]'),
    };

    function fmt(n) {
      if (!isFinite(n)) n = 0;
      return '$' + n.toFixed(2);
    }

    function getQuantity() {
      var input = document.getElementById('Quantity-' + sectionId);
      if (input) {
        var q = parseInt(input.value, 10);
        if (q > 0) return q;
      }
      return 1;
    }

    function getCurrentFootPrice() {
      var variant = data.variants[String(currentVariantId)];
      if (!variant) return 0;
      var qty = getQuantity();
      if (variant.breaks && variant.breaks.length) {
        var sorted = variant.breaks.slice().sort(function (a, b) { return b.min - a.min; });
        for (var i = 0; i < sorted.length; i++) {
          if (qty >= sorted[i].min) return sorted[i].price;
        }
      }
      return variant.price || 0;
    }

    function recalc() {
      var footPrice = getCurrentFootPrice();
      var inchPrice = footPrice / 12;
      var mult = parseFloat(els.multiplier.value) || 0;
      // Per spec: multiplier only affects the final Retail Price.
      var sellingInch = inchPrice;
      var length = parseInt(els.length.value, 10) || 0;
      var braceletChainPrice = sellingInch * length;
      var other = parseFloat(els.other.value) || 0;
      var labor = parseFloat(els.labor.value) || 0;
      var totalCost = braceletChainPrice + other + labor;
      var retail = totalCost * mult;

      els.foot.textContent = fmt(footPrice);
      els.inch.textContent = fmt(inchPrice);
      els.multiplierDisplay.textContent = mult.toFixed(1) + 'x';
      els.sellingInch.textContent = fmt(sellingInch);
      els.lengthDisplay.textContent = length;
      els.braceletPrice.textContent = fmt(braceletChainPrice);
      els.totalCost.textContent = fmt(totalCost);
      els.retail.textContent = fmt(retail);
    }

    ['input', 'change'].forEach(function (evt) {
      root.addEventListener(evt, recalc);
    });

    if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
      subscribe(PUB_SUB_EVENTS.variantChange, function (event) {
        if (event && event.data && event.data.variant && event.data.variant.id) {
          currentVariantId = event.data.variant.id;
        }
        recalc();
      });
    }

    var qtyInput = document.getElementById('Quantity-' + sectionId);
    if (qtyInput) {
      qtyInput.addEventListener('change', recalc);
      qtyInput.addEventListener('input', recalc);
    }

    recalc();
  })();
</script>
