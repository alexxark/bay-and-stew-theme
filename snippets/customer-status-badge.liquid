{%- comment -%}
  Renders the customer account status badge ("Signed Out", "Signed in (Wholesale)", etc.).

  Accepts:
    - class: {String} optional extra class name(s) to apply to the badge
{%- endcomment -%}
{%- liquid
  assign status_class = 'status-badge--out'
  assign status_text = 'Signed Out'

  if customer
    assign tag_str = customer.tags | join: ',' | downcase
    if tag_str contains 'b2b'
      assign status_class = 'status-badge--wholesale'
      assign status_text = 'Signed in (Wholesale)'
    elsif tag_str contains 'shop' or tag_str contains 'retail'
      assign status_class = 'status-badge--retail'
      assign status_text = 'Signed in (Retail)'
    else
      assign status_class = 'status-badge--retail'
      assign status_text = 'Signed in'
    endif
  endif
-%}
{%- if customer -%}
  <span class="status-badge {{ status_class }} {{ class }}">{{ status_text }}</span>
{%- else -%}
  {%- assign login_return_url = request.path -%}
  {%- if request.query_string != blank -%}
    {%- assign login_return_url = login_return_url | append: '?' | append: request.query_string -%}
  {%- endif -%}
  {%- assign login_href = routes.account_login_url | append: '?checkout_url=' | append: login_return_url | url_encode -%}
  <span class="status-badge-wrapper {{ class }}" tabindex="0">
    <span class="status-badge {{ status_class }}">
      {{ status_text }}<span class="status-badge__asterisk" aria-hidden="true">*</span>
    </span>
    <span class="status-badge-info__tooltip" role="tooltip">
      <a href="{{ routes.account_login_url }}?checkout_url={{ login_return_url | url_encode }}">Sign in</a>
      to wholesale account or apply for wholesale
      <a href="https://bayandstew.com/pages/apply-for-wholesale">here</a>
      for tax free purchasing and updated pricing
    </span>
  </span>
{%- endif -%}
