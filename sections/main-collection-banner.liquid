{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .collection-hero__title {
    font-size: {{ section.settings.title_font_size | times: 0.75 }}px;
  }
  #shopify-section-{{ section.id }} .collection-hero__description {
    font-size: {{ section.settings.description_font_size | times: 0.85 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .collection-hero__title {
      font-size: {{ section.settings.title_font_size }}px;
    }
    #shopify-section-{{ section.id }} .collection-hero__description {
      font-size: {{ section.settings.description_font_size }}px;
    }
  }
  @media screen and (max-width: 749px) {
    .collection-hero--with-image .collection-hero__inner {
      padding-bottom: calc({{ settings.media_shadow_vertical_offset | at_least: 0 }}px + 2rem);
    }
  }
{%- endstyle -%}

{%- assign has_description = false -%}
{%- if section.settings.show_collection_description and collection.description != blank -%}
  {%- assign has_description = true -%}
{%- endif -%}
{%- assign has_image = false -%}
{%- if section.settings.show_collection_image and collection.image -%}
  {%- assign has_image = true -%}
{%- endif -%}
{%- assign is_collapsible = false -%}
{%- if section.settings.collapsible_description and has_description -%}
  {%- assign is_collapsible = true -%}
{%- endif -%}

<div class="collection-hero{% if has_image %} collection-hero--with-image{% endif %}{% if is_collapsible %} collection-hero--collapsible{% endif %} color-{{ section.settings.color_scheme }} gradient">
  <div class="collection-hero__inner page-width {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    <div class="collection-hero__text-wrapper">
      {%- if is_collapsible -%}
        <details class="collection-hero__collapsible">
          <summary>
            <h1 class="collection-hero__title">
              <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
              {{- collection.title | escape -}}
            </h1>
            <svg class="icon-caret" viewBox="0 0 10 6" xmlns="http://www.w3.org/2000/svg" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="collection-hero__collapsible-content">
            <div class="collection-hero__description rte">{{ collection.description }}</div>
            {%- if has_image -%}
              <div class="collection-hero__image-container media gradient">
                {%- render 'collection-hero-image', collection: collection, settings: settings -%}
              </div>
            {%- endif -%}
          </div>
        </details>
      {%- else -%}
        <h1 class="collection-hero__title">
          <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
          {{- collection.title | escape -}}
        </h1>
        {%- if has_description -%}
          <div class="collection-hero__description rte">{{ collection.description }}</div>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- unless is_collapsible -%}
      {%- if has_image -%}
        <div class="collection-hero__image-container media gradient">
          <img
            srcset="
              {%- if collection.image.width >= 165 -%}{{ collection.image | image_url: width: 165 }} 165w,{%- endif -%}
              {%- if collection.image.width >= 360 -%}{{ collection.image | image_url: width: 360 }} 360w,{%- endif -%}
              {%- if collection.image.width >= 535 -%}{{ collection.image | image_url: width: 535 }} 535w,{%- endif -%}
              {%- if collection.image.width >= 750 -%}{{ collection.image | image_url: width: 750 }} 750w,{%- endif -%}
              {%- if collection.image.width >= 1070 -%}{{ collection.image | image_url: width: 1070 }} 1070w,{%- endif -%}
              {%- if collection.image.width >= 1500 -%}{{ collection.image | image_url: width: 1500 }} 1500w,{%- endif -%}
              {{ collection.image | image_url }} {{ collection.image.width }}w
            "
            src="{{ collection.image | image_url: width: 750 }}"
            sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc(50vw - 130px), calc(50vw - 55px)"
            alt="{{ collection.image.alt | escape }}"
            width="{{ collection.image.width }}"
            height="{{ collection.image.height }}"
          >
        </div>
      {%- endif -%}
    {%- endunless -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": false,
      "label": "t:sections.main-collection-banner.settings.show_collection_image.label",
      "info": "t:sections.main-collection-banner.settings.show_collection_image.info"
    },
    {
      "type": "checkbox",
      "id": "collapsible_description",
      "default": false,
      "label": "Collapse description and image",
      "info": "Shows only the title with a 'Read more' toggle. Description and image stay in the page for SEO."
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 18,
      "max": 54,
      "step": 2,
      "unit": "px",
      "default": 40,
      "label": "Title font size"
    },
    {
      "type": "range",
      "id": "description_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15,
      "label": "Description font size"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
