{%- comment -%}
  ================================================================
  1. LOCKING LOGIC
  This block determines if the entire collection page is locked.
  ================================================================
{%- endcomment -%}
{%- liquid
  assign locked_collection_handles = 'bracelet,earrings,necklace,ready-to-wear,rings' | split: ','

  assign is_b2b_customer = false
  if customer and customer.tags contains 'B2B'
    assign is_b2b_customer = true
  endif

  assign is_page_locked = false
  if locked_collection_handles contains collection.handle and is_b2b_customer == false
    assign is_page_locked = true
  endif
-%}

{%- comment -%}
  ================================================================
  2. PAGE DISPLAY
  Shows either the "Access Denied" message or the product grid.
  ================================================================
{%- endcomment -%}
{%- if is_page_locked -%}
  <div class="page-width" style="text-align: center; padding: 50px 0 100px;">
    <h2>Wholesale Access Only</h2>
    <p>You must be a B2B customer to access this collection. Please <a href="/account/login?checkout_url={{ request.path | url_encode }}">log in</a> or <a href="/pages/wholesale-sales-tax-exemption-requirements?checkout_url={{ request.path | url_encode }}">register here</a>.</p>
  </div>
{%- else -%}
{%- comment -%} Preload critical CSS for faster initial render {%- endcomment -%}
<link rel="preload" href="{{ 'component-price.css' | asset_url }}" as="style">
<link rel="preload" href="{{ 'component-card.css' | asset_url }}" as="style">

{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- comment -%} Critical inline CSS to prevent layout shifts during price loading {%- endcomment -%}
<style>
  /* Reserve space for price to prevent CLS */
  .price { min-height: 1.4em; }
  .price__container { min-height: 1.2em; }
  
  /* CSS containment for better rendering performance */
  .product-card-wrapper {
    contain: layout style;
    content-visibility: auto;
    contain-intrinsic-size: auto 350px;
  }
  
  /* Optimize repaints during hover */
  .card__media img {
    will-change: transform;
  }
  
  /* Ensure prices render immediately */
  .price-item { display: inline-block; }
  
  /* Optimize grid item rendering - each item is isolated */
  #product-grid > li {
    contain: layout style paint;
  }
  
  /* Faster fade-in animation */
  .load-more-fade-in {
    animation: loadMoreFadeIn 0.25s ease-out forwards;
  }
  
  /* Price loading skeleton for BSS B2B processing */
  .load-more-fade-in .price__container:empty::before,
  .load-more-fade-in [bss-b2b-product-price]:empty::before {
    content: '';
    display: inline-block;
    width: 60px;
    height: 1em;
    background: linear-gradient(90deg, #e0e0e0 25%, #f0f0f0 50%, #e0e0e0 75%);
    background-size: 200% 100%;
    animation: priceShimmer 1.2s infinite;
    border-radius: 3px;
  }
  
  @keyframes priceShimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
  
  /* Once BSS populates the price, hide skeleton */
  .bss-b2b-collection-item-vat:not(:empty) .bss-b2b-product-vat-price-no-vat:not(:empty)::before,
  .bss-b2b-collection-item-vat:not(:empty) .bss-b2b-product-vat-price-has-vat:not(:empty)::before {
    display: none;
  }
</style>

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ===== LOAD MORE BUTTON ===== */
  .load-more-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin: 3rem 0;
  }

  #load-more-btn {
    cursor: pointer;
    transition: all 0.3s ease;
  }

  #load-more-btn:focus-visible {
    outline: 3px solid currentColor;
    outline-offset: 2px;
  }

  #load-more-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Loading spinner */
  .load-more-spinner {
    display: inline-block;
    width: 20px;
    height: 20px;
    border: 3px solid rgba(0, 0, 0, 0.1);
    border-radius: 50%;
    border-top-color: currentColor;
    animation: load-more-spin 0.8s linear infinite;
  }

  @keyframes load-more-spin {
    to { transform: rotate(360deg); }
  }

  /* Fade-in for newly loaded products - GPU accelerated */
  @keyframes loadMoreFadeIn {
    from { opacity: 0; transform: translate3d(0, 8px, 0); }
    to { opacity: 1; transform: translate3d(0, 0, 0); }
  }

  /* Screen reader only */
  .load-more-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  {%- paginate collection.products by 12 -%}
    {% comment %} Sort is the first tabbable element when filter type is vertical {% endcomment %}
    {%- if section.settings.enable_sorting and section.settings.filter_type == 'vertical' -%}
      <facet-filters-form class="facets facets-vertical-sort page-width small-hide">
        <form class="facets-vertical-form" id="FacetSortForm">
          <div class="facet-filters sorting caption">
            <div class="facet-filters__field">
              <h2 class="facet-filters__label caption-large text-body">
                <label for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>
              </h2>
              <div class="select">
                {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                <select
                  name="sort_by"
                  class="facet-filters__sort select__select caption-large"
                  id="SortBy"
                  aria-describedby="a11y-refresh-page-message"
                >
                  {%- for option in collection.sort_options -%}
                    <option
                      value="{{ option.value | escape }}"
                      {% if option.value == sort_by %}
                        selected="selected"
                      {% endif %}
                    >
                      {{ option.name | escape }}
                    </option>
                  {%- endfor -%}
                </select>
                <span class="svg-wrapper">
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
              </div>
            </div>
          </div>

          <div class="product-count-vertical light" role="status">
            <h2 class="product-count__text text-body">
              <span id="ProductCountDesktop">
                {%- if collection.results_count -%}
                  {{
                    'templates.search.results_with_count'
                    | t: terms: collection.terms, count: collection.results_count
                  }}
                {%- elsif collection.products_count == collection.all_products_count -%}
                  {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
                {%- else -%}
                  {{
                    'products.facets.product_count'
                    | t: product_count: collection.products_count, count: collection.all_products_count
                  }}
                {%- endif -%}
              </span>
            </h2>
            {%- render 'loading-spinner' -%}
          </div>
        </form>
      </facet-filters-form>
    {%- endif -%}

    <div class="{% if section.settings.filter_type == 'vertical' %} facets-vertical page-width{% endif %}">
      {{ 'component-facets.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
      {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
        <aside
          aria-labelledby="verticalTitle"
          aria-label="{{ 'products.facets.filter_and_sort' | t | default: 'Filter and sort' }}"
          class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
          id="main-collection-filters"
          data-id="{{ section.id }}"
        >
          {% render 'facets',
            results: collection,
            enable_filtering: section.settings.enable_filtering,
            enable_sorting: section.settings.enable_sorting,
            filter_type: section.settings.filter_type,
            paginate: paginate
          %}
        </aside>
      {%- endif -%}

      <div
        class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        id="ProductGridContainer"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        {%- if collection.products.size == 0 -%}
          <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              <h2 class="title title--primary">
                {{ 'sections.collection_template.empty' | t -}}
                <br>
                {{
                  'sections.collection_template.use_fewer_filters_html'
                  | t: link: collection.url, class: 'underlined-link link'
                }}
              </h2>
            </div>
          </div>
        {%- else -%}
          <div
            class="collection{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
          >
            <div class="loading-overlay gradient"></div>
            <ul
              id="product-grid"
              data-id="{{ section.id }}"
              class="
                grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down
                grid--{{ section.settings.columns_desktop }}-col-desktop
                {% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %}
              "
            >
              {%- comment -%}
                Locked collection handles for B2B gating.
                Non-B2B customers won't see products from these collections.
              {%- endcomment -%}
              {%- assign locked_collection_handles = 'bracelets,earrings,necklace,ready-to-wear,rings' | split: ',' -%}
              {%- assign is_b2b_customer = false -%}
              {%- if customer and customer.tags contains 'B2B' -%}
                {%- assign is_b2b_customer = true -%}
              {%- endif -%}

              {% assign skip_card_product_styles = false %}
              {%- for product in collection.products -%}
                {%- comment -%} B2B lock check: skip the entire <li> if product is locked {%- endcomment -%}
                {%- unless is_b2b_customer -%}
                  {%- assign is_product_locked = false -%}
                  {%- for product_collection in product.collections -%}
                    {%- if locked_collection_handles contains product_collection.handle -%}
                      {%- assign is_product_locked = true -%}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if is_product_locked -%}
                    {%- continue -%}
                  {%- endif -%}
                {%- endunless -%}

                {%- comment -%}start BSS Commerce Hide Price{%- endcomment -%}
                {%- capture bss_lock_check -%}{%- render 'bss-lock-condition', scope: 'subject', subject: product, variable: 'transparent' -%}{%- endcapture -%}
                {%- if bss_lock_check contains 'true' -%}{%- continue -%}{%- endif -%}
                {%- comment -%}end BSS Commerce Hide Price{%- endcomment -%}

                {% assign lazy_load = false %}
                {%- if forloop.index > 2 -%}
                  {%- assign lazy_load = true -%}
                {%- endif -%}
                <li
                  class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                  {% endif %}
                >
                  {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    image_shape: section.settings.image_shape,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    lazy_load: lazy_load,
                    skip_styles: skip_card_product_styles,
                    quick_add: section.settings.quick_add,
                    section_id: section.id
                  %}
                </li>
                {%- assign skip_card_product_styles = true -%}
              {%- endfor -%}
            </ul>

            {%- comment -%} Load More button replaces standard pagination {%- endcomment -%}
            {%- if paginate.next -%}
              <div class="load-more-container" id="load-more-wrapper">
                <button
                  id="load-more-btn"
                  class="button"
                  type="button"
                  data-next-url="{{ paginate.next.url }}"
                  aria-label="Load more products in the {{ collection.title }} collection"
                  aria-busy="false"
                >
                  Load More Products
                </button>
                <div id="loading-spinner" class="load-more-spinner" style="display: none;" aria-hidden="true"></div>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
  {% if section.settings.image_shape == 'arch' %}
    {{ 'mask-arch.svg' | inline_asset_content }}
  {%- endif -%}
</div>
{%- endif -%}

{%- comment -%}
  ================================================================
  LOAD MORE JAVASCRIPT
  Uses event delegation so it works after filter changes replace the DOM.
  Optimized for performance with batched DOM updates.
  ADA compliant with screen reader announcements.
  ================================================================
{%- endcomment -%}
<script>
  (function() {
    var loadMoreListenerAttached = false;

    function handleLoadMoreClick(e) {
      var btn = e.target.closest('#load-more-btn');
      if (!btn) return;

      e.preventDefault();

      var loadingSpinner = document.getElementById('loading-spinner');
      var loadMoreWrapper = document.getElementById('load-more-wrapper');
      var productGrid = document.getElementById('product-grid');

      if (!productGrid) return;

      btn.disabled = true;
      btn.setAttribute('aria-busy', 'true');
      if (loadingSpinner) loadingSpinner.style.display = 'inline-block';

      var nextUrl = btn.dataset.nextUrl;
      if (!nextUrl) {
        console.error('Load more: No next URL found');
        btn.disabled = false;
        return;
      }

      fetch(nextUrl)
        .then(function(response) {
          return response.text();
        })
        .then(function(html) {
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');
          var newItems = doc.querySelectorAll('#product-grid > li');

          if (newItems.length > 0) {
            // Use DocumentFragment for batched DOM insertion (single reflow)
            var fragment = document.createDocumentFragment();
            
            // Process all items before touching the DOM
            var itemsArray = Array.from(newItems);
            itemsArray.forEach(function(item, index) {
              // Skip cloning - move the parsed node directly (faster)
              item.classList.add('load-more-fade-in');
              item.style.cssText = 'opacity:1;transform:translateY(0);animation-delay:' + (index * 0.03) + 's';
              item.classList.remove('scroll-trigger');
              fragment.appendChild(item);
            });

            // Single DOM insertion - triggers only one reflow
            requestAnimationFrame(function() {
              productGrid.appendChild(fragment);
              
              // Trigger BSS B2B price refresh for newly added items
              triggerBSSPriceRefresh(productGrid);
              
              announceLoadMoreToScreenReader(itemsArray.length + ' new products loaded');
            });
          }

          // Update button state
          var currentBtn = document.getElementById('load-more-btn');
          var currentSpinner = document.getElementById('loading-spinner');
          var currentWrapper = document.getElementById('load-more-wrapper');
          var newLoadMoreBtn = doc.querySelector('#load-more-btn');

          if (newLoadMoreBtn && newLoadMoreBtn.dataset.nextUrl && currentBtn) {
            currentBtn.dataset.nextUrl = newLoadMoreBtn.dataset.nextUrl;
            currentBtn.disabled = false;
            currentBtn.setAttribute('aria-busy', 'false');
            if (currentSpinner) currentSpinner.style.display = 'none';
          } else {
            if (currentWrapper) currentWrapper.style.display = 'none';
            if (currentSpinner) currentSpinner.style.display = 'none';
          }
        })
        .catch(function(error) {
          console.error('Load more error:', error);
          var currentBtn = document.getElementById('load-more-btn');
          var currentSpinner = document.getElementById('loading-spinner');
          if (currentBtn) {
            currentBtn.disabled = false;
            currentBtn.setAttribute('aria-busy', 'false');
          }
          if (currentSpinner) currentSpinner.style.display = 'none';
        });
    }

    // Trigger BSS B2B and other third-party apps to process new price elements
    function triggerBSSPriceRefresh(container) {
      // Method 1: Dispatch Shopify section events that apps listen to
      var sectionEvent = new CustomEvent('shopify:section:load', {
        bubbles: true,
        detail: { sectionId: container.closest('[data-section-id]')?.dataset.sectionId }
      });
      document.dispatchEvent(sectionEvent);
      
      // Method 2: Dispatch a generic DOM content loaded event for apps using that
      var contentEvent = new CustomEvent('bss:content:updated', { bubbles: true });
      container.dispatchEvent(contentEvent);
      
      // Method 3: Call BSS global refresh functions if they exist
      if (typeof window.BSSB2B !== 'undefined' && typeof window.BSSB2B.refresh === 'function') {
        window.BSSB2B.refresh();
      }
      if (typeof window.BSSCommerce !== 'undefined' && typeof window.BSSCommerce.initPrices === 'function') {
        window.BSSCommerce.initPrices(container);
      }
      
      // Method 4: Re-trigger the page's price calculation scripts
      // Some apps use MutationObserver but need a "poke" to notice changes
      var priceElements = container.querySelectorAll('[bss-b2b-product-price]');
      priceElements.forEach(function(el) {
        // Toggle an attribute to trigger MutationObserver
        el.setAttribute('data-bss-refresh', Date.now());
      });
      
      // Method 5: Dispatch custom event commonly used by pricing apps
      document.dispatchEvent(new CustomEvent('price:refresh', { 
        detail: { container: container }
      }));
      
      // Method 6: For tax display VAT elements
      var vatElements = container.querySelectorAll('.bss-b2b-collection-item-vat');
      if (vatElements.length > 0 && typeof window.BssB2BTax !== 'undefined') {
        if (typeof window.BssB2BTax.calculate === 'function') {
          window.BssB2BTax.calculate();
        }
      }
      
      // Method 7: Retry mechanism - wait for BSS scripts to be ready
      var retryCount = 0;
      var maxRetries = 5;
      function retryBSSInit() {
        retryCount++;
        if (retryCount > maxRetries) return;
        
        // Check if prices are still empty
        var emptyPrices = container.querySelectorAll('.load-more-fade-in .bss-b2b-collection-item-vat');
        var hasEmptyVat = false;
        emptyPrices.forEach(function(el) {
          var noVat = el.querySelector('.bss-b2b-product-vat-price-no-vat');
          var hasVat = el.querySelector('.bss-b2b-product-vat-price-has-vat');
          if ((noVat && !noVat.textContent.trim()) || (hasVat && !hasVat.textContent.trim())) {
            hasEmptyVat = true;
          }
        });
        
        if (hasEmptyVat) {
          // Retry triggers
          document.dispatchEvent(new CustomEvent('shopify:section:load', { bubbles: true }));
          if (typeof window.BSSB2B !== 'undefined' && window.BSSB2B.refresh) window.BSSB2B.refresh();
          if (typeof window.BSSCommerce !== 'undefined' && window.BSSCommerce.init) window.BSSCommerce.init();
          if (typeof window.BssB2BTax !== 'undefined' && window.BssB2BTax.calculate) window.BssB2BTax.calculate();
          
          // Try again after delay
          setTimeout(retryBSSInit, 500 * retryCount);
        }
      }
      
      // Start retry after initial delay
      setTimeout(retryBSSInit, 300);
    }

    function announceLoadMoreToScreenReader(message) {
      var announcer = document.getElementById('load-more-announcer');
      if (!announcer) {
        announcer = document.createElement('div');
        announcer.id = 'load-more-announcer';
        announcer.className = 'load-more-sr-only';
        announcer.setAttribute('role', 'status');
        announcer.setAttribute('aria-live', 'polite');
        document.body.appendChild(announcer);
      }
      announcer.textContent = '';
      setTimeout(function() {
        announcer.textContent = message;
      }, 100);
    }

    // Attach delegated listener once to document body - survives any DOM replacement
    if (!loadMoreListenerAttached) {
      document.addEventListener('click', handleLoadMoreClick);
      loadMoreListenerAttached = true;
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:sections.main-collection-product-grid.settings.columns_desktop.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__3.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__3.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.main-collection-product-grid.settings.image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_shape",
      "options": [
        {
          "value": "default",
          "label": "t:sections.all.image_shape.options__1.label"
        },
        {
          "value": "arch",
          "label": "t:sections.all.image_shape.options__2.label"
        },
        {
          "value": "blob",
          "label": "t:sections.all.image_shape.options__3.label"
        },
        {
          "value": "chevronleft",
          "label": "t:sections.all.image_shape.options__4.label"
        },
        {
          "value": "chevronright",
          "label": "t:sections.all.image_shape.options__5.label"
        },
        {
          "value": "diamond",
          "label": "t:sections.all.image_shape.options__6.label"
        },
        {
          "value": "parallelogram",
          "label": "t:sections.all.image_shape.options__7.label"
        },
        {
          "value": "round",
          "label": "t:sections.all.image_shape.options__8.label"
        }
      ],
      "default": "default",
      "label": "t:sections.all.image_shape.label",
      "info": "t:sections.all.image_shape.info"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.show_secondary_image.label"
    },
    {
