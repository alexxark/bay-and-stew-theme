{{ 'favorites.css' | asset_url | stylesheet_tag }}
<script src="{{ 'favorites.js' | asset_url }}" defer="defer"></script>

<div
  class="bs-favorites"
  data-bs-favorites-page
  data-logged-in="{% if customer %}true{% else %}false{% endif %}"
>
  <h1 class="bs-favorites__title">{{ section.settings.title | default: 'My Favorites' }}</h1>

  {%- unless customer -%}
    <div class="bs-favorites__signin">
      <p>{{ section.settings.signin_text | default: 'Please sign in to view and manage your favorites.' }}</p>
      <a class="button button--primary" href="{{ routes.account_login_url }}?checkout_url={{ request.path | url_encode }}">
        {{ 'customer.log_in' | t }}
      </a>
    </div>
  {%- else -%}
    <div data-bs-favorites-root>
      <p class="bs-favorites__loading">Loading your favorites…</p>
    </div>

    {%- comment -%}
      Server-rendered inventory + price map for the customer's favorited
      products. Storefront product JSON (/products/handle.js) does NOT expose
      inventory_quantity AND returns the public price, ignoring B2B /
      wholesale rules. Liquid sees the signed-in customer, so we emit both
      from Liquid here for the JS to use.
    {%- endcomment -%}
    {%- assign fav_handles = customer.metafields.favorites.handles.value -%}
    {%- if fav_handles -%}
      {%- capture fav_inventory_json -%}
        {
        {%- for handle in fav_handles -%}
          {%- assign p = all_products[handle] -%}
          {%- if p and p.id -%}
            "{{ handle }}":{
            {%- for v in p.variants -%}
              "{{ v.id }}":{
                "tracked":{% if v.inventory_management == 'shopify' and v.inventory_policy != 'continue' %}true{% else %}false{% endif %},
                "qty":{{ v.inventory_quantity | default: 0 }}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
            }{% unless forloop.last %},{% endunless %}
          {%- endif -%}
        {%- endfor -%}
        }
      {%- endcapture -%}
      <script type="application/json" data-bs-favorites-inventory>{{ fav_inventory_json }}</script>

      {%- comment -%}
        Hidden price bootstrap: render the standard BSS-aware price markup
        for every favorited variant. The BSS B2B app naturally observes
        these elements at page load and rewrites them with the customer's
        wholesale price. The favorites JS then clones the already-correct
        HTML into each visible variant row, so wholesale pricing "just
        works" without us having to hand off to BSS at runtime.
      {%- endcomment -%}
      <div data-bs-favorites-prices hidden aria-hidden="true" style="display:none">
        {%- for handle in fav_handles -%}
          {%- assign p = all_products[handle] -%}
          {%- if p and p.id -%}
            {%- for v in p.variants -%}
              <span
                data-bs-fav-price
                data-bs-handle="{{ handle }}"
                data-bs-variant="{{ v.id }}"
                bss-b2b-product-id="{{ p.id }}"
                bss-b2b-product-price
                bss-b2b-variant-price
                bss-b2b-variant-id="{{ v.id }}"
              >
                {%- if v.compare_at_price and v.compare_at_price > v.price -%}
                  <s class="bs-fav-variant__compare">{{ v.compare_at_price | money }}</s>
                  <span class="bs-fav-variant__sale">{{ v.price | money }}</span>
                {%- else -%}
                  {{ v.price | money }}
                {%- endif -%}
              </span>
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endunless -%}
</div>

{% schema %}
{
  "name": "Favorites",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Page title",
      "default": "My Favorites"
    },
    {
      "type": "text",
      "id": "signin_text",
      "label": "Sign-in prompt",
      "default": "Please sign in to view and manage your favorites."
    }
  ],
  "presets": [
    {
      "name": "Favorites"
    }
  ]
}
{% endschema %}
